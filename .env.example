# --- OVMS ---
OVMS_IMAGE=openvino/model_server:latest-gpu
OVMS_REST_PORT=8000
OVMS_GRPC_PORT=9000

# --- Open WebUI ---
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_PORT=3000
OPENWEBUI_AUTH=False

# --- Pipelines (ReAct agent) ---
PIPELINES_API_KEY=change-me-to-something-random

# --- HuggingFace ---
# Crea uno en https://huggingface.co/settings/tokens (read-only basta para descargar modelos públicos).
# Solo necesario si vas a descargar modelos gated.
HF_TOKEN=
